# ─────────────────────────────────────────────────────────────
# Patrika Engine — environment
# Copy to .env.local and fill in. The core app needs ONLY the three
# Supabase values below. There are NO AI keys to set — clustering is
# pure text-matching (no embeddings, no LLM).
# ─────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────
# Dashboard → Project Settings → API.
# Paste each value right after the = with NO trailing comment or spaces.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY is server-only — never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron (optional) ──────────────────────────────────────────
# Protects POST/GET to /api/cron/ingest when triggered manually.
# On Vercel, the platform's cron runner is trusted automatically.
CRON_SECRET=

# ── Kill-switches (optional) ─────────────────────────────────
# SKIP_FETCH=1     # stop pulling new articles
# SKIP_CLUSTER=1   # stop building trends

# ─────────────────────────────────────────────────────────────
# OPTIONAL — only if you turn on the AI "write a draft" button.
# The trend engine never uses these.
# ─────────────────────────────────────────────────────────────
# KEY_ENCRYPTION_SECRET=          # openssl rand -hex 32 (encrypts stored AI keys)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GROQ_API_KEY=
