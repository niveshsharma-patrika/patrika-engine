# ── Patrika Engine — server .env (copy to `.env` on the Azure VM) ──────────
# Never commit the real .env. Generate secrets with:  openssl rand -hex 32

# ── REQUIRED ───────────────────────────────────────────────────────────────
# Azure Database for PostgreSQL connection string (or any managed Postgres).
DATABASE_URL=postgres://USER:PASSWORD@your-db.postgres.database.azure.com:5432/patrika_engine
# Managed Postgres enforces TLS — keep this on in production.
PGSSL=require

# Local port the app listens on (nginx proxies to it). Pick one not used by the
# other PM2 sites.
PORT=3007
HOSTNAME=127.0.0.1

# Session signing (login) — 32+ random bytes. REQUIRED for auth to work.
AUTH_SECRET=replace-with-openssl-rand-hex-32

# Protects the /api/cron/ingest endpoint the scheduler calls.
CRON_SECRET=replace-with-openssl-rand-hex-32

# AI — OpenAI is the active provider (drafts, widgets, categorisation).
OPENAI_API_KEY=sk-...

# ── OPTIONAL ───────────────────────────────────────────────────────────────
# Fallback AI provider (used only if OPENAI_API_KEY is unset).
# GOOGLE_GENERATIVE_AI_API_KEY=...

# Model overrides (sensible defaults shown).
# OPENAI_MODEL=gpt-4o-mini        # default per-tick + Patrika drafts
# WIDGET_MODEL=gpt-4.1            # interactive widgets
# STYLE_DRAFT_MODEL=gpt-4.1       # distinctive outlet-style drafts

# Postgres pool size (default 10).
# PG_POOL_MAX=10

# Only if you store admin-configured AI keys encrypted in the DB (ai_providers).
# KEY_ENCRYPTION_SECRET=...
